# Cryptobot environment variables — copy to .env and fill in.

# Database
POSTGRES_PASSWORD=devpass
DATABASE_URL=postgresql+asyncpg://cryptobot:devpass@localhost:5432/cryptobot
DATABASE_URL_SYNC=postgresql+psycopg://cryptobot:devpass@localhost:5432/cryptobot

# API port (defaults to 8000; override if you have port collisions)
API_PORT=8000

# Exchange API keys — withdrawals disabled, IP-whitelisted
BINANCE_API_KEY=
BINANCE_API_SECRET=
BYBIT_API_KEY=
BYBIT_API_SECRET=
HYPERLIQUID_WALLET_PRIVATE_KEY=

# Per-strategy sub-account keys (optional, Phase 13)
BINANCE_API_KEY_FUNDING_ARB=
BINANCE_API_SECRET_FUNDING_ARB=
BINANCE_API_KEY_FACTOR_PF=
BINANCE_API_SECRET_FACTOR_PF=

# Backup wallet rotation slots (Phase 11)
BINANCE_API_KEY_FUNDING_ARB_A=
BINANCE_API_SECRET_FUNDING_ARB_A=
BINANCE_API_KEY_FUNDING_ARB_B=
BINANCE_API_SECRET_FUNDING_ARB_B=

# Anthropic for LLM overlay (optional — empty disables)
ANTHROPIC_API_KEY=

# DB pool tuning (HP7; defaults are 5/10/30.0)
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30.0
